# ══════════════════════════════════════════════════════════════
# WOLFIE DELIVERY — .env.example
# ══════════════════════════════════════════════════════════════

# App
FLASK_ENV=development
SECRET_KEY=change-this-in-production-32-chars-min
JWT_SECRET_KEY=wolfie-jwt-change-in-prod-32-chars

# Database (Supabase)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_MEMORY=256mb

# Celery
WORKER_CONCURRENCY=4
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=wolfie123

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mapbox
MAPBOX_TOKEN=pk.eyJ1...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+13475550000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://wolfie.app

# Business Rules
BASE_DELIVERY_FEE=4.00
DELIVERY_FEE_PER_KM=0.80
DELIVERY_FEE_PER_MIN=0.12
SERVICE_FEE_RATE=0.12
SERVICE_FEE_MIN=3.49
SERVICE_FEE_MAX=7.49
SURGE_MULTIPLIER_MAX=2.5
DRIVER_TRIAL_DAYS=7
RESTAURANT_TRIAL_DAYS=30
MIN_COMMISSION_RATE=0.10
MAX_COMMISSION_RATE=0.18
