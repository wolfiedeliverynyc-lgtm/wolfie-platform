# App
FLASK_ENV=development
SECRET_KEY=wolfie-secret-dev-key-2026-change-in-prod
JWT_SECRET_KEY=wolfie-jwt-dev-key-2026-change-in-prod

# Database (SQLite for dev, Supabase for prod)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=sqlite:///wolfie_dev.db

# Redis (optional - falls back to memory if not running)
REDIS_URL=redis://localhost:6379

# Celery
WORKER_CONCURRENCY=4

# Stripe (mock mode - no real key needed)
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_PUBLISHABLE_KEY=pk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock

# Mapbox
MAPBOX_TOKEN=pk.eyJ1Ijoid29sZmllZGVsaXZlcnkiLCJhIjoiY21vcjV2YW41MXlrYTJxcGhocWtqOGRhayJ9.bDuoURrNHs2QoZQcMBQhCQ

# Twilio (mock SMS - OTP logged to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MOCK_SMS=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://localhost:3001

# Business Rules
BASE_DELIVERY_FEE=4.00
