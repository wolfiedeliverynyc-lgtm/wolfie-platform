DRIVER_TRIAL_DAYS=7
RESTAURANT_TRIAL_DAYS=30
MIN_COMMISSION_RATE=0.10
MAX_COMMISSION_RATE=0.18

# Mock Settings
MOCK_PAYMENT=true
MOCK_SMS=true
MOCK_PUSH=true
